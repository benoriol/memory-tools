#!/usr/bin/env bash
# mem - install, update, or remove the memory-commands slash commands for a project.
#
# Two profiles:
#   generic  the /mem-* commands targeting journal / knowledge / canon
#   paper    the same /mem-* command names, targeting experiments (+ an important subset),
#            technical notes, and a paper narrative
#
# Two install modes:
#   copy (default)  each project owns real copies of the command files, so you can customise
#                   them per project. Refresh later with `mem update` (it preserves your edits).
#   --link          symlink into the module instead, so `git pull` in the module updates every
#                   linked project at once (but local edits would change the module; and symlinks
#                   break when the project repo is cloned without the module).
#
# Per-project notes + the CLAUDE.md contract are set up by the /mem-init slash command (whichever
# profile is installed), not this CLI.
set -euo pipefail
shopt -s nullglob

# Resolve through symlinks so this works when `mem` itself is symlinked onto PATH.
SELF="$(readlink -f "${BASH_SOURCE[0]}")"
MODULE_DIR="$(cd "$(dirname "$SELF")" && pwd)"

# Per-profile source dir + filename glob.
GENERIC_DIR="$MODULE_DIR/commands"
GENERIC_GLOB="mem*.md"
PAPER_DIR="$MODULE_DIR/profiles/paper/commands"
PAPER_GLOB="mem*.md"

# Default target is the current project's command dir; override with CLAUDE_COMMANDS_DIR.
DEST_DIR="${CLAUDE_COMMANDS_DIR:-$PWD/.claude/commands}"
# Tracks what this CLI installed (name, profile, mode, baseline hash) so update/uninstall can
# tell an upstream change from a local customisation.
MANIFEST="$DEST_DIR/.mem-manifest"

profile_dir()  { case "$1" in generic) echo "$GENERIC_DIR" ;; paper) echo "$PAPER_DIR" ;; esac; }
profile_glob() { case "$1" in generic) echo "$GENERIC_GLOB" ;; paper) echo "$PAPER_GLOB" ;; esac; }

# Content fingerprint (POSIX cksum: checksum + byte count). Enough to detect edits.
_hash() { cksum < "$1" | awk '{print $1"-"$2}'; }

# Manifest helpers (tab-separated: name  profile  mode  baseline_hash).
manifest_get()   { [ -f "$MANIFEST" ] && awk -F'\t' -v n="$1" '$1==n' "$MANIFEST" || true; }
mf_field()       { printf '%s' "$1" | cut -f"$2"; }
manifest_set() {
  local name="$1" prof="$2" mode="$3" h="$4" tmp
  mkdir -p "$DEST_DIR"; tmp="$(mktemp)"
  [ -f "$MANIFEST" ] && awk -F'\t' -v n="$name" '$1!=n' "$MANIFEST" > "$tmp" || true
  printf '%s\t%s\t%s\t%s\n' "$name" "$prof" "$mode" "$h" >> "$tmp"
  mv "$tmp" "$MANIFEST"
}
manifest_del() {
  [ -f "$MANIFEST" ] || return 0
  local tmp; tmp="$(mktemp)"
  awk -F'\t' -v n="$1" '$1!=n' "$MANIFEST" > "$tmp" || true
  if [ -s "$tmp" ]; then mv "$tmp" "$MANIFEST"; else rm -f "$tmp" "$MANIFEST"; fi
}

usage() {
  cat <<EOF
mem - manage the memory-commands slash commands (per-project)

Usage:
  mem install [generic|paper] [--link]   copy a profile's commands into ./.claude/commands
                                         (default), or --link to symlink them instead
  mem install                            auto-detect the profile, then confirm
  mem update  [generic|paper] [--force]  refresh copied commands from the module, keeping any
                                         you have edited locally (--force overwrites them)
  mem status                             show each command's state (copied / linked / modified)
  mem uninstall                          remove this module's commands here (keeps your edited copies)
  mem help                               this message

Profiles (both install the same /mem-* command names; one profile per project):
  generic  journal / knowledge / canon                              <- $GENERIC_DIR
  paper    experiments (+important) / technical notes / narrative   <- $PAPER_DIR

Module:  $MODULE_DIR
Target:  $DEST_DIR
  (override the target with the CLAUDE_COMMANDS_DIR environment variable)

Run from a project's root. Copies are real files you can edit per project; `mem update` refreshes
them and skips anything you changed. `--link` symlinks instead (module edits propagate via
git pull, but break on clone). After installing, run /mem-init to scaffold the notes.
EOF
}

# Guess the profile from filesystem signals. Echoes "generic" or "paper"; reason -> stderr.
detect_profile() {
  local reasons=()
  [ -d "$PWD/paper_writeups" ]               && reasons+=("paper_writeups/")
  [ -d "$PWD/wandb" ]                        && reasons+=("wandb/")
  [ -d "$PWD/checkpoints" ]                  && reasons+=("checkpoints/")
  [ -d "$PWD/project_notes/experiments" ]    && reasons+=("project_notes/experiments/")
  [ -f "$PWD/project_notes/experiments.md" ] && reasons+=("project_notes/experiments.md")
  local tex; tex=( "$PWD"/*.tex ); [ ${#tex[@]} -gt 0 ] && reasons+=("*.tex")
  local line; for line in "$PWD"/project_notes/*/experiments.md; do reasons+=("$(basename "$(dirname "$line")")/experiments.md"); done
  if [ ${#reasons[@]} -gt 0 ]; then
    echo "detected research signals: ${reasons[*]} -> suggesting 'paper'" >&2; echo paper
  else
    echo "no research signals found -> suggesting 'generic'" >&2; echo generic
  fi
}

# Resolve the profile: explicit arg, else auto-detect + (if interactive) confirm.
resolve_profile() {
  local arg="${1:-}"
  if [ -n "$arg" ]; then
    case "$arg" in generic|paper) echo "$arg"; return 0 ;; *) echo "unknown profile: $arg" >&2; return 1 ;; esac
  fi
  local guess; guess="$(detect_profile)"
  if [ -t 0 ]; then
    local ans; read -r -p "Install profile '$guess'? [Y]es / (g)eneric / (p)aper / (n)o: " ans
    case "$ans" in
      ""|y|Y|yes) echo "$guess" ;;
      g|generic)  echo generic ;;
      p|paper)    echo paper ;;
      *)          echo "aborted." >&2; return 1 ;;
    esac
  else
    echo "non-interactive; using '$guess' (pass 'generic'/'paper' to override)" >&2; echo "$guess"
  fi
}

cmd_install() {
  local profile="" mode="copy" a
  for a in "$@"; do
    case "$a" in
      --copy) mode=copy ;;
      --link) mode=link ;;
      generic|paper) profile="$a" ;;
      *) echo "unknown install arg: $a" >&2; exit 1 ;;
    esac
  done
  profile="$(resolve_profile "$profile")" || exit 1
  local src glob; src="$(profile_dir "$profile")"; glob="$(profile_glob "$profile")"
  mkdir -p "$DEST_DIR"
  local n=0 f name link srch ent tgt desth base
  for f in "$src"/$glob; do
    name="$(basename "$f")"; link="$DEST_DIR/$name"; srch="$(_hash "$f")"
    ent="$(manifest_get "$name")"
    if [ -L "$link" ]; then
      tgt="$(readlink -f "$link" 2>/dev/null || true)"
      case "$tgt" in "$MODULE_DIR"/*) : ;; *) echo "skip  $name (foreign symlink; not touching)"; continue ;; esac
    elif [ -e "$link" ]; then
      if [ -n "$ent" ]; then
        desth="$(_hash "$link")"; base="$(mf_field "$ent" 4)"
        if [ "$desth" != "$srch" ] && [ "$desth" != "$base" ]; then
          echo "skip  $name (locally modified; use 'mem update --force' to overwrite)"; continue
        fi
      else
        echo "skip  $name (a real file exists; not overwriting)"; continue
      fi
    fi
    rm -f "$link"
    if [ "$mode" = link ]; then ln -sfn "$f" "$link"; echo "link  $name"; else cp "$f" "$link"; echo "copy  $name"; fi
    manifest_set "$name" "$profile" "$mode" "$srch"; n=$((n + 1))
  done
  echo "installed $n '$profile' command(s) ($mode) into $DEST_DIR"
}

cmd_update() {
  local force=0 profile="" a
  for a in "$@"; do case "$a" in --force) force=1 ;; generic|paper) profile="$a" ;; *) echo "unknown update arg: $a" >&2; exit 1 ;; esac; done
  if [ ! -f "$MANIFEST" ]; then echo "nothing installed here (no manifest at $MANIFEST)"; return 0; fi
  local snap; snap="$(mktemp)"; cp "$MANIFEST" "$snap"
  local n=0 name prof mode base f link srch desth
  # Refresh tracked entries.
  while IFS=$'\t' read -r name prof mode base; do
    [ -n "${name:-}" ] || continue
    [ -z "$profile" ] || [ "$profile" = "$prof" ] || continue
    f="$(profile_dir "$prof")/$name"; link="$DEST_DIR/$name"
    if [ ! -e "$f" ]; then echo "gone  $name (no longer in module '$prof'); kept local copy"; continue; fi
    if [ "$mode" = link ]; then echo "link  $name (symlink; auto-updates)"; continue; fi
    srch="$(_hash "$f")"
    if [ ! -e "$link" ]; then cp "$f" "$link"; manifest_set "$name" "$prof" copy "$srch"; echo "add   $name (restored)"; n=$((n + 1)); continue; fi
    desth="$(_hash "$link")"
    if [ "$desth" = "$srch" ]; then echo "ok    $name (up to date)"; continue; fi
    if [ "$desth" = "$base" ]; then
      cp "$f" "$link"; manifest_set "$name" "$prof" copy "$srch"; echo "upd   $name (module changed)"; n=$((n + 1))
    elif [ "$force" = 1 ]; then
      cp "$f" "$link"; manifest_set "$name" "$prof" copy "$srch"; echo "upd   $name (overwrote local changes)"; n=$((n + 1))
    else
      echo "skip  $name (locally modified; module differs — merge by hand or use --force)"
    fi
  done < "$snap"
  rm -f "$snap"
  # Pull in commands newly added to the module (not yet tracked) for the installed profile(s).
  local profs prof dir glob
  if [ -n "$profile" ]; then profs="$profile"; else profs="$(cut -f2 "$MANIFEST" | sort -u)"; fi
  for prof in $profs; do
    dir="$(profile_dir "$prof")"; glob="$(profile_glob "$prof")"
    for f in "$dir"/$glob; do
      name="$(basename "$f")"; [ -z "$(manifest_get "$name")" ] || continue
      link="$DEST_DIR/$name"
      if [ -e "$link" ] && [ ! -L "$link" ]; then echo "skip  $name (untracked real file)"; continue; fi
      cp "$f" "$link"; manifest_set "$name" "$prof" copy "$(_hash "$f")"; echo "add   $name (new in module)"; n=$((n + 1))
    done
  done
  echo "updated $n command(s) in $DEST_DIR"
}

cmd_uninstall() {
  local n=0 kept=0 link tgt name prof mode base desth snap
  # Our symlinks (resolve into the module).
  for link in "$DEST_DIR"/*.md; do
    [ -L "$link" ] || continue
    tgt="$(readlink -f "$link" 2>/dev/null || true)"
    case "$tgt" in "$MODULE_DIR"/*) name="$(basename "$link")"; rm -f "$link"; echo "rm    $name"; n=$((n + 1)); manifest_del "$name" ;; esac
  done
  # Our tracked copies: remove the untouched ones, keep anything you edited.
  if [ -f "$MANIFEST" ]; then
    snap="$(mktemp)"; cp "$MANIFEST" "$snap"
    while IFS=$'\t' read -r name prof mode base; do
      [ -n "${name:-}" ] || continue
      [ "$mode" = copy ] || continue
      link="$DEST_DIR/$name"
      if [ ! -e "$link" ]; then manifest_del "$name"; continue; fi
      desth="$(_hash "$link")"
      if [ "$desth" = "$base" ]; then rm -f "$link"; echo "rm    $name"; n=$((n + 1)); manifest_del "$name"
      else echo "keep  $name (locally modified; delete by hand if unwanted)"; kept=$((kept + 1)); fi
    done < "$snap"
    rm -f "$snap"
  fi
  if [ "$kept" -gt 0 ]; then echo "removed $n command(s), kept $kept modified, from $DEST_DIR"
  else echo "removed $n command(s) from $DEST_DIR"; fi
}

cmd_status() {
  echo "target dir: $DEST_DIR"
  # Both profiles share command names, so a project has one installed set. The manifest is the
  # source of truth for what we installed and from which profile.
  if [ ! -f "$MANIFEST" ]; then
    echo "no memory-commands installed here."
    echo "available profiles: generic, paper  (run: mem install [generic|paper])"
    return 0
  fi
  local name prof mode base src link srch desth state tgt
  while IFS=$'\t' read -r name prof mode base; do
    [ -n "${name:-}" ] || continue
    src="$(profile_dir "$prof")/$name"; link="$DEST_DIR/$name"
    if [ ! -e "$link" ] && [ ! -L "$link" ]; then
      state="missing"
    elif [ "$mode" = link ]; then
      if [ -L "$link" ]; then
        tgt="$(readlink -f "$link" 2>/dev/null || true)"
        case "$tgt" in "$MODULE_DIR"/*) state="linked" ;; *) state="link replaced by other target" ;; esac
      else state="link replaced by a real file"; fi
    else
      srch="$(_hash "$src" 2>/dev/null || echo none)"; desth="$(_hash "$link")"
      if   [ "$desth" = "$srch" ]; then state="copied, up to date"
      elif [ "$desth" = "$base" ]; then state="copied, update available"
      else state="copied, modified"; fi
    fi
    printf '  %-16s %-8s %s\n' "$name" "$prof" "$state"
  done < "$MANIFEST"
}

case "${1:-help}" in
  install)        shift; cmd_install "$@" ;;
  update)         shift; cmd_update "$@" ;;
  uninstall)      cmd_uninstall ;;
  status)         cmd_status ;;
  help | -h | --help) usage ;;
  *) echo "unknown command: ${1}" >&2; echo; usage; exit 1 ;;
esac
